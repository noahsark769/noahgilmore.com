{
  "name": "noahgilmore.com",
  "description": "My personal website",
  "version": "1.0.0",
  "author": "Noah Gilmore",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "classnames": "^2.5.1",
    "feed": "^4.2.2",
    "gh-pages": "^2.0.1",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "next-mdx-remote": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga": "^3.3.1",
    "react-icons": "^3.11.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.5.0",
    "react-twitter-embed": "^4.0.4",
    "rehype-img-size": "^1.0.1",
    "slugify": "^1.6.5",
    "tailwindcss": "^4.2.1"
  },
  "license": "MIT",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsgo --noEmit",
    "generate:rss": "tsx scripts/rss.ts",
    "prebuild": "pnpm run generate:rss && pnpm run generate:sitemap",
    "generate:sitemap": "tsx scripts/sitemap.ts",
    "cf:build": "pnpm build && opennextjs-cloudflare build",
    "preview": "pnpm run cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "deploy:staging": "pnpm run cf:build && wrangler deploy --name noahgilmore-website-staging"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript/native-preview": "7.0.0-dev.20260312.1",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vercel": "^37.5.3",
    "wrangler": "^4.72.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby-starter-default"
  },
  "type": "module"
}
